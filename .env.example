# Sınav Asistanım — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.

# NextAuth.js — oturum yönetimi
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # openssl rand -base64 32 ile oluşturun

# Veritabanı (SQLite geliştirme ortamı için)
DATABASE_URL="file:./dev.db"

# Groq API — Hızlı AI çağrıları (sohbet, soru üretme)
GROQ_API_KEY=""

# Google Gemini API — PDF analizi ve multimodal işleme
GOOGLE_GENERATIVE_AI_API_KEY=""

# Çoklu Gemini API Key'leri — kota yönetimi için (virgülle ayrılmış)
# Farklı Google hesaplarından key oluşturun: https://aistudio.google.com/apikey
GEMINI_API_KEYS=""
